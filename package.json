{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm lint:page-namespaces && pnpm lint:entity-mappings && nuxt build",
    "dev": "nuxt dev -o",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "lint:admin-imports": "node scripts/check-admin-legacy-imports.mjs",
    "legacy:migration:inventory": "node scripts/generate-legacy-migration-inventory.mjs",
    "legacy:migration:check": "node scripts/check-legacy-migration-status.mjs",
    "legacy:imports:check": "node scripts/check-legacy-imports.mjs",
    "legacy:no-require:check": "node scripts/check-legacy-no-require.mjs",
    "lint:fullcalendar-imports": "node scripts/check-fullcalendar-vue-imports.mjs",
    "legacy:pages:kpi": "node scripts/legacy-pages-kpi.mjs",
    "legacy:page-meta:check": "node scripts/check-legacy-page-meta.mjs",
    "lint:admin-paths": "node scripts/check-admin-path-convention.mjs",
    "lint:entity-mappings": "node scripts/check-entity-mappings.mjs",
    "endpoint:inventory:generate": "node scripts/generate-endpoint-usage-report.mjs",
    "endpoint:inventory:check": "node scripts/check-endpoint-inventory.mjs",
    "lint:admin-parent-routes": "node scripts/check-admin-parent-nuxtpage-children.mjs",
    "lint:page-namespaces": "node scripts/check-page-namespace-duplicates.mjs"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/test-utils": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.0",
    "happy-dom": "^20.6.1",
    "nuxt-echarts": "^1.0.1",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.97.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4",
    "vuetify-nuxt-module": "^0.19.5"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
