    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@nuxtjs/i18n": "^9.5.4",
    "@pinia/nuxt": "^0.11.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@vueuse/nuxt": "^14.2.1",
    "echarts": "^6.0.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.28",
    "pinia": "^3.0.4",
    "vuetify": "^3.11.8",
    "xlsx": "^0.18.5"
  }
